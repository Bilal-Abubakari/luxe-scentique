# =============================================
# Luxe Scentique - Environment Configuration
# =============================================
# Copy this file to .env and fill in your values

# ----- Database -----
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/luxe_scentique?schema=public"

# ----- Application -----
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:4200
ADMIN_URL=http://localhost:4201

# ----- JWT Auth -----
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production
JWT_EXPIRES_IN=7d

# ----- Google OAuth -----
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ----- Paystack -----
PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key
PAYSTACK_BASE_URL=https://api.paystack.co
# Webhook signature uses PAYSTACK_SECRET_KEY (no separate secret needed)

# ----- Cloudflare R2 -----
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=luxe-scentique-assets
R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# ----- Super Admin Seed -----
SUPER_ADMIN_EMAIL=abubakaribilal99@gmail.com
