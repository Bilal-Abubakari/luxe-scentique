# =============================================
# Luxe Scentique - Environment Configuration
# =============================================
# Copy this file to .env and fill in your values

# ----- Database -----
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/luxe_scentique?schema=public"

# ----- Application -----
NODE_ENV=development
PORT=3003
FRONTEND_URL=http://localhost:4200
ADMIN_URL=http://localhost:4201

# ----- JWT Auth -----
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production
JWT_EXPIRES_IN=7d

# ----- Google OAuth -----
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ----- Paystack -----
PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key
PAYSTACK_BASE_URL=https://api.paystack.co
# Webhook signature uses PAYSTACK_SECRET_KEY (no separate secret needed)

# ----- Cloudinary -----
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
# e.g. https://api.cloudinary.com/v1_1/{cloud_name}/image/upload
CLOUDINARY_BASE_URL=https://api.cloudinary.com/v1_1/your-cloud-name/image/upload
# Upload preset names configured in your Cloudinary dashboard
CLOUDINARY_PRODUCTS=

# ----- Super Admin Seed -----
SUPER_ADMIN_EMAIL=abubakaribilal99@gmail.com

# ----- Email -----
# Provider: "mailtrap" (dev/staging) or "smtp" (production)
EMAIL_PROVIDER=mailtrap
EMAIL_FROM_NAME=Luxe Scentique
EMAIL_FROM_ADDRESS=noreply@luxescentique.com

# Mailtrap sandbox (from mailtrap.io → Inboxes → SMTP Settings)
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=your-mailtrap-user
MAILTRAP_PASS=your-mailtrap-pass

# Generic SMTP (SendGrid, Mailgun, Postmark, AWS SES — set EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Admin inbox — receives a notification email for every new order placed
ADMIN_NOTIFICATION_EMAIL=luxescentique.parfum@gmail.com
