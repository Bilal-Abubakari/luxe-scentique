// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  role      Role     @default(CUSTOMER)
  googleId  String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]

  @@map("users")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CUSTOMER
}

// ─── Products ────────────────────────────────────────────────────────────────

model Product {
  id          String      @id @default(cuid())
  title       String
  brand       String
  vibe        ProductVibe?
  description String?
  topNotes    String[]
  middleNotes String[]
  baseNotes   String[]
  price       Float
  stock       Int         @default(0)
  images      String[]
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]

  @@map("products")
}

enum ProductVibe {
  CORPORATE
  CASUAL
  EVENING
  SPORT
  UNISEX
  FEMININE
  MASCULINE
  LUXURY
}

// ─── Orders ──────────────────────────────────────────────────────────────────

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique
  customerId    String?
  customer      User?         @relation(fields: [customerId], references: [id])
  customerEmail String
  customerPhone String?
  customerName  String?
  items         OrderItem[]
  subtotal      Float
  serviceFee    Float         @default(0)
  total         Float
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod @default(ONLINE)
  paymentRef    String?
  isPaid        Boolean       @default(false)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float   // price at time of order

  @@map("order_items")
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  ONLINE
  WALK_IN
}

// ─── Finance ─────────────────────────────────────────────────────────────────

model Expense {
  id          String          @id @default(cuid())
  title       String
  amount      Float
  category    ExpenseCategory
  date        DateTime
  vendor      String?
  description String?
  reference   String?
  receiptUrl  String?
  recordedBy  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("expenses")
}

model OtherIncome {
  id          String         @id @default(cuid())
  title       String
  amount      Float
  category    IncomeCategory
  date        DateTime
  source      String?
  description String?
  reference   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("other_income")
}

enum ExpenseCategory {
  INVENTORY_PURCHASE
  SALARY
  RENT
  UTILITIES
  MARKETING
  SUPPLIES
  TRANSPORT
  MAINTENANCE
  TAX
  INSURANCE
  OTHER
}

enum IncomeCategory {
  INVESTMENT
  LOAN
  GRANT
  REFUND
  COMMISSION
  OTHER
}

