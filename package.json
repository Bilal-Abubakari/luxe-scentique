{
  "name": "luxe-scentique",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate --schema=apps/api/prisma/schema.prisma",
    "start:prod": "prisma migrate deploy --schema=apps/api/prisma/schema.prisma && node dist/apps/api/main.js",
    "dev": "nx run-many -t serve --projects=api,admin-panel,storefront --parallel",
    "dev:api": "nodemon --config apps/api/nodemon.json",
    "dev:storefront": "nx dev storefront",
    "dev:admin": "nx serve admin-panel --configuration=development",
    "start:api": "nx serve api",
    "start:storefront": "nx dev storefront",
    "start:admin": "nx serve admin-panel",
    "build": "nx run-many -t build",
    "build:api": "nx build api --configuration=production",
    "build:storefront": "nx build storefront --configuration=production",
    "build:admin": "nx build admin-panel --configuration=production",
    "build:admin:staging": "nx build admin-panel --configuration=staging",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "prisma:generate": "prisma generate --schema=apps/api/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema=apps/api/prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=apps/api/prisma/schema.prisma",
    "prisma:migrate:status": "prisma migrate status --schema=apps/api/prisma/schema.prisma",
    "prisma:migrate:reset": "prisma migrate reset --schema=apps/api/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=apps/api/prisma/schema.prisma",
    "prisma:seed": "ts-node -r dotenv/config apps/api/prisma/seed.ts"
  },
